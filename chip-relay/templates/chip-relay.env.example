# chip-relay local runtime config. Copy to .env and edit. Do not commit .env.
CHIP_RELAY_BACKEND=auto
CHIP_RELAY_HOST=127.0.0.1
CHIP_RELAY_PORT=18800
CHIP_RELAY_PROFILE=default
# CHIP_RELAY_PROFILE_DIR=$HOME/.local/share/chip-relay/profiles/default
CHIP_RELAY_DISPLAY=:1002
CHIP_RELAY_HEADLESS=0
CHIP_RELAY_LAUNCH_TIMEOUT=60

# Optional explicit browser binaries.
# CHIP_RELAY_CLOAK_BIN=$HOME/.local/bin/cloakbrowser-chrome
# CHIP_RELAY_BROWSEROS_BIN=/usr/bin/browseros
# CHIP_RELAY_CHROMIUM_BIN=/usr/bin/chromium

# CloakBrowser wrapper settings.
CLOAKBROWSER_CACHE_DIR=$HOME/.local/share/chip-relay/cloakbrowser-cache
CLOAKBROWSER_FINGERPRINT_PLATFORM=windows
# CLOAKBROWSER_FINGERPRINT_SEED=12345
