# ==== GitHub ====

# Имя пользователя (или организации) GitHub, под которым создаются репозитории.
# См. в правом верхнем углу github.com (аватар -> Your profile).
GITHUB_USERNAME=your_github_username

# Персональный access token GitHub с правами:
# - repo (полный доступ к приватным репозиториям),
# - read:org (если нужен доступ к организациям).
# Где получить:
# GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# -> Generate new token (classic).
GITHUB_TOKEN=ghp_example_personal_access_token

# Идентификатор установки GitHub App Vercel.
# Получение:
# GitHub -> Settings -> Applications -> Installed GitHub Apps -> Vercel -> Configure.
# В URL будет фрагмент /installations/NNNNNN, это и есть installation_id.
GITHUB_APP_INSTALLATION_ID=12345678

# ==== Vercel ====

# Персональный или team‑token Vercel, используется для REST API.
# Где получить:
# Vercel -> Account Settings или Team Settings -> Tokens / Access Tokens -> Generate Token.
VERCEL_TOKEN=vercel_example_token

# Идентификатор команды Vercel (если деплой должен идти в команду, а не в личный аккаунт).
# Можно оставить пустым для личного аккаунта.
# Найти можно в Vercel Settings -> Team -> General
# или через API: GET https://api.vercel.com/v2/teams
VERCEL_TEAM_ID=

# Необязательное явное имя проекта/репозитория.
# Если не задано, агент может использовать имя текущей папки.
# REPO_NAME=my-project-name